@using DiceCombats
@using MudBlazor.Utilities
@inject DiceCombatsService CombatService
@inject IStringLocalizer<Resources.Localization.CreatureCustomFieldRenderer> Loc

@if (EditionMode)
{
    <MudNumericField @bind-Value="Field.Count" Label="@Loc["CreatureStatsCount"]" style="max-width:200px;" Variant="Variant.Outlined" />
    <MudCheckBox Label="@Loc["CreatureStatsKeepValuesEditable"]" @bind-Value="Field.ValuesAreEditable"></MudCheckBox>
    <MudStack Row="true" style="overflow:auto;">
        @foreach (int i in Enumerable.Range(0, Field.Count))
        {
            <MudStack Row="false">
                <MudTextField style="min-width:100px;" Immediate="true" @bind-Value="Field.StatsLabels[i]" Label="@Loc["CreatureStatsStatLabel"]" Variant="Variant.Outlined" />
                <MudNumericField @bind-Value="Field.StatsValues[i]" Label="@Field.StatsLabels[i]" Variant="Variant.Outlined" />
            </MudStack>
        }
    </MudStack>
}
else
{
    <div style="zoom: 0.85;">
        <MudStack Row="true">
            @foreach (int i in Enumerable.Range(0, Field.Count))
            {
                var index = i;
                <MudStack Row="false" Style="border-radius:5px;border-width:thin;background-color:darkcyan;">
                    @if (Field.ValuesAreEditable)
                    {
                        <MudItem Style="padding-left:5px;padding-right:5px;text-align:center;font-weight:200;font-size:14px;">@Field.StatsLabels[index]</MudItem>
                        <MudNumericField T="int" Value="@Field.StatsValues[index]" ValueChanged="@((int v) => OnStatValueChanged(index, v))" style="max-width:90px;" Variant="Variant.Outlined" />
                    }
                    else
                    {
                        <MudItem Style="text-align:center;font-weight:400;font-size:18px;">@Field.StatsValues[index]</MudItem>
                        <MudItem Style="padding-left:5px;padding-right:5px;text-align:center;font-weight:200;font-size:14px;">@Field.StatsLabels[index]</MudItem>
                    }
                </MudStack>
            }
        </MudStack>
    </div>
}

@code {
    [Parameter] public DCCreatureStatsField Field { get; set; } = default!;
    [Parameter] public bool EditionMode { get; set; } = false;
    [Parameter] public EventCallback OnChange { get; set; }
    [Parameter] public EventCallback<CustomFieldChangeInfo> OnFieldChanged { get; set; }

    private async Task OnStatValueChanged(int index, int value)
    {
        var oldValue = Field.StatsValues[index];
        Field.StatsValues[index] = value;

        if (OnFieldChanged.HasDelegate)
        {
            await OnFieldChanged.InvokeAsync(new CustomFieldChangeInfo
            {
                Field = Field,
                OldValue = oldValue,
                NewValue = value,
                Action = "Changed",
                ChangeDirection = GetChangeDirection(oldValue, value),
                StatIndex = index,
                StatName = Field.StatsLabels.ElementAtOrDefault(index)
            });
        }

        if (OnChange.HasDelegate)
            await OnChange.InvokeAsync();
    }

    private static string GetChangeDirection(int oldValue, int newValue)
    {
        if (newValue > oldValue) return "Increased";
        if (newValue < oldValue) return "Decreased";
        return "Unchanged";
    }
}
