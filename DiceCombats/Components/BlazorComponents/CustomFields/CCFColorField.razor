@using DiceCombats
@using MudBlazor.Utilities
@inject DiceCombatsService CombatService
@inject IStringLocalizer<Resources.Localization.CreatureCustomFieldRenderer> Loc

@if (EditionMode)
{
    <MudColorPicker Variant="Variant.Outlined" ColorPickerView="ColorPickerView.GridCompact" Label="@Loc["ColorPickerName"]" Text="@Field.Value" TextChanged="OnColorChanged" Style="@($"color: {Field.Value};")" Placeholder="Select Color" />
}
else
{
    <div style="zoom: 0.85;">
        <MudStack Row="true" Wrap="Wrap.Wrap">
            @if (_showColorPicker)
            {
                <div @onclick="ToggleColorPicker">
                    <MudColorPicker PickerVariant="PickerVariant.Static"
                                    ColorPickerView="ColorPickerView.GridCompact"
                                    Variant="Variant.Outlined" Label="@Loc["ColorPickerName"]"
                                    Text="@Field.Value"
                                    TextChanged="OnColorChanged"
                                    Style="@($"color: {Field.Value ?? ""};")" Placeholder="Select Color" />
                </div>
                <span style="@($"cursor:pointer;background-color:{Field.Value ?? ""};border-radius:5px;border-width:1px;border-color:grey;width:50px;height:50px;")" @onclick="ToggleColorPicker">&nbsp;Close&nbsp;</span>
            }
            else
            {
                <span class="CreatureCustomFieldRendererFieldTitle">@Field.Title</span>
                <span style="@($"cursor:pointer;background-color:{Field.Value ?? ""};border-radius:5px;border-width:1px;border-color:grey;width:50px;height:50px;")" @onclick="ToggleColorPicker">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>
            }

        </MudStack>
    </div>
}

@code {
    [Parameter] public DCCreatureColorField Field { get; set; } = default!;
    [Parameter] public bool EditionMode { get; set; } = false;
    [Parameter] public EventCallback OnChange { get; set; }
    [Parameter] public EventCallback<CustomFieldChangeInfo> OnFieldChanged { get; set; }

    private bool _showColorPicker = false;

    private async Task ToggleColorPicker()
    {
        _showColorPicker = !_showColorPicker;
        if (OnChange.HasDelegate)
            await OnChange.InvokeAsync();
    }

    private async Task OnColorChanged(string value)
    {
        var oldValue = Field.Value;
        Field.Value = value;

        if (OnFieldChanged.HasDelegate)
        {
            await OnFieldChanged.InvokeAsync(new CustomFieldChangeInfo
            {
                Field = Field,
                OldValue = oldValue,
                NewValue = value,
                Action = "Changed"
            });
        }

        if (OnChange.HasDelegate)
            await OnChange.InvokeAsync();
    }
}
