@using DiceCombats.Automations
@inject DiceCombatsService CombatService
@inject IStringLocalizer<Resources.Localization.Automations> Loc

@{
    var triggerEntry = GetTriggerEntry(Trigger);
}

<MudPaper Class="pa-2 my-2" Style="background-color:#202020;border-radius:10px;">
    <MudText Typo="Typo.h6">@Loc["When"]</MudText>
    <MudSelect T="string" Value="@Trigger.Kind" ValueChanged="SetTriggerKind" Label="@Loc["Trigger"]">
        @foreach (var ev in EventTriggerCatalog.Entries)
        {
            <MudSelectItem T="string" Value="@ev.Kind">@GetTriggerSelectText(ev)</MudSelectItem>
        }
    </MudSelect>

    @if (triggerEntry.SupportsCreatureFilter)
    {
        <MudSelect T="string"
                   MultiSelection="true"
                   SelectedValues="@Trigger.CreatureNames"
                   SelectedValuesChanged="@((IEnumerable<string> values) => Trigger.CreatureNames = values.ToList())"
                   Label="@Loc["CreaturesEmptyAnyCreature"]">
            @foreach (var creatureName in GetCreatureNames())
            {
                <MudSelectItem T="string" Value="@creatureName">@creatureName</MudSelectItem>
            }
        </MudSelect>
    }

    @if (triggerEntry.NeedsField)
    {
        <MudSelect T="string" @bind-Value="Trigger.FieldTitle" Label="@Loc["CustomFieldEmptyAnyMatchingField"]">
            <MudSelectItem T="string" Value="@String.Empty"></MudSelectItem>
            @foreach (var field in GetFieldChoices(triggerEntry))
            {
                <MudSelectItem T="string" Value="@field.Title">@GetFieldChoiceDisplayName(field)</MudSelectItem>
            }
        </MudSelect>
    }

    @if (triggerEntry.NeedsOption)
    {
        <MudSelect T="string" @bind-Value="Trigger.OptionName" Label="@Loc["OptionEmptyAnyOption"]">
            <MudSelectItem T="string" Value="@String.Empty"></MudSelectItem>
            @foreach (var optionName in GetOptionNames(triggerEntry.FieldType, Trigger.FieldTitle))
            {
                <MudSelectItem T="string" Value="@optionName">@optionName</MudSelectItem>
            }
        </MudSelect>
    }

    @if (triggerEntry.NeedsStat)
    {
        <MudSelect T="string" @bind-Value="Trigger.StatName" Label="@Loc["StatEmptyAnyStat"]">
            <MudSelectItem T="string" Value="@String.Empty"></MudSelectItem>
            @foreach (var statName in GetStatNames(Trigger.FieldTitle))
            {
                <MudSelectItem T="string" Value="@statName">@statName</MudSelectItem>
            }
        </MudSelect>
    }

    @if (triggerEntry.NeedsThreshold)
    {
        <MudSelect T="string" @bind-Value="Trigger.ThresholdOperator" Label="@Loc["Comparison"]">
            @foreach (var op in _thresholdOperators)
            {
                <MudSelectItem T="string" Value="@op">@GetThresholdOperatorDisplay(op)</MudSelectItem>
            }
        </MudSelect>
        <MudNumericField T="double?" @bind-Value="Trigger.ThresholdValue" Label="@GetThresholdLabel(triggerEntry)" />
        <MudSwitch @bind-Value="Trigger.TriggerOnlyOnCrossing" Color="Color.Primary" Label="@Loc["OnlyWhenValueCrossesThreshold"]" />
    }

    <MudText Typo="Typo.caption">@GetTriggerSummary(Trigger)</MudText>
</MudPaper>

@code {
    [Parameter] public EventTriggerDefinition Trigger { get; set; } = new();

    private readonly List<string> _thresholdOperators = ["Below", "BelowOrEqual", "Above", "AboveOrEqual"];

    private void SetTriggerKind(string kind)
    {
        Trigger.Kind = kind;
        Trigger.FieldTitle = string.Empty;
        Trigger.OptionName = string.Empty;
        Trigger.StatName = string.Empty;
        Trigger.ThresholdValue = null;
    }

    private static EventTriggerCatalogEntry GetTriggerEntry(EventTriggerDefinition trigger)
    {
        return EventTriggerCatalog.Get(trigger.Kind) ?? EventTriggerCatalog.Entries.First();
    }

    private IReadOnlyList<string> GetCreatureNames()
    {
        return CombatService.GetCreatureList()
            .Select(x => x.Name)
            .Concat(CombatService.GetCombatList().SelectMany(x => x.CreaturesList).Select(x => x.Name))
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x)
            .ToList();
    }

    private IReadOnlyList<CustomFieldChoice> GetFieldChoices(EventTriggerCatalogEntry triggerEntry)
    {
        return GetKnownCustomFields()
            .Where(x => IsFieldChoiceCompatible(x, triggerEntry))
            .GroupBy(x => new { x.Title, x.FieldType })
            .Select(x => new CustomFieldChoice(x.Key.Title, x.Key.FieldType))
            .OrderBy(x => x.Title)
            .ThenBy(x => x.FieldType)
            .ToList();
    }

    private static bool IsFieldChoiceCompatible(DCCreatureCustomField field, EventTriggerCatalogEntry triggerEntry)
    {
        if (!string.IsNullOrWhiteSpace(triggerEntry.FieldType) && !string.Equals(field.FieldType, triggerEntry.FieldType, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        return triggerEntry.Kind != EventTriggerKinds.NumericReachedMaxValue || field is DCCreatureNumericField { ShowMaxValue: true };
    }

    private IReadOnlyList<string> GetOptionNames(string fieldType, string fieldTitle)
    {
        return GetKnownCustomFields()
            .Where(x => string.IsNullOrWhiteSpace(fieldTitle) || string.Equals(x.Title, fieldTitle, StringComparison.OrdinalIgnoreCase))
            .Where(x => string.IsNullOrWhiteSpace(fieldType) || string.Equals(x.FieldType, fieldType, StringComparison.OrdinalIgnoreCase))
            .SelectMany(field => field switch
            {
                DCCreatureCheckboxField checkbox => checkbox.Labels,
                DCCreatureConditionsField conditions => conditions.Labels,
                _ => Enumerable.Empty<string>()
            })
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x)
            .ToList();
    }

    private IReadOnlyList<string> GetStatNames(string fieldTitle)
    {
        return GetKnownCustomFields()
            .OfType<DCCreatureStatsField>()
            .Where(x => string.IsNullOrWhiteSpace(fieldTitle) || string.Equals(x.Title, fieldTitle, StringComparison.OrdinalIgnoreCase))
            .SelectMany(x => x.StatsLabels)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x)
            .ToList();
    }

    private IEnumerable<DCCreatureCustomField> GetKnownCustomFields()
    {
        foreach (var field in CombatService.GetUserCreatureCustomFields())
            yield return field;

        foreach (var creature in CombatService.GetCreatureList())
            foreach (var field in creature.CustomFields)
                yield return field;

        foreach (var combat in CombatService.GetCombatList())
        {
            foreach (var creature in combat.CreaturesList)
                foreach (var field in creature.CustomFields)
                    yield return field;

            foreach (var creatureFields in combat.InCombatCustomFieldsInstances)
                foreach (var instanceFields in creatureFields)
                    foreach (var field in instanceFields)
                        yield return field;
        }
    }

    private string GetTriggerSummary(EventTriggerDefinition trigger)
    {
        var entry = GetTriggerEntry(trigger);
        var creatureText = trigger.CreatureNames.Count == 0 ? Loc["TriggerSummaryAnyCreature"].Value : string.Join(", ", trigger.CreatureNames);
        var fieldText = string.IsNullOrWhiteSpace(trigger.FieldTitle) ? Loc["TriggerSummaryAnyMatchingField"].Value : Loc["TriggerSummaryField", trigger.FieldTitle].Value;
        var optionText = string.IsNullOrWhiteSpace(trigger.OptionName) ? Loc["TriggerSummaryAnyOption"].Value : Loc["TriggerSummaryOption", trigger.OptionName].Value;
        var statText = string.IsNullOrWhiteSpace(trigger.StatName) ? Loc["TriggerSummaryAnyStat"].Value : Loc["TriggerSummaryStat", trigger.StatName].Value;

        if (trigger.Kind == EventTriggerKinds.NumericReachedMaxValue) return Loc["TriggerSummaryNumericReachedMaxValue", fieldText, creatureText].Value;
        if (entry.NeedsThreshold) return Loc["TriggerSummaryThreshold", fieldText, creatureText, GetThresholdOperatorDisplay(trigger.ThresholdOperator), trigger.ThresholdValue].Value;
        if (entry.NeedsStat) return Loc["TriggerSummaryStatChanged", statText, fieldText, creatureText].Value;
        if (entry.NeedsOption) return Loc["TriggerSummaryOptionChanged", optionText, fieldText, creatureText].Value;
        if (entry.NeedsField) return Loc["TriggerSummaryFieldChanged", fieldText, creatureText].Value;
        if (entry.SupportsCreatureFilter) return Loc["TriggerSummaryCreatureFilter", creatureText].Value;
        return Loc["TriggerSummaryDefault", GetTriggerDisplayName(entry)].Value;
    }

    private string GetTriggerSelectText(EventTriggerCatalogEntry entry)
    {
        return $"{GetTriggerCategory(entry)} - {GetTriggerDisplayName(entry)}";
    }

    private string GetTriggerCategory(EventTriggerCatalogEntry entry)
    {
        return Loc[$"TriggerCategory_{entry.Category.Replace(" ", "")}"].Value;
    }

    private string GetTriggerDisplayName(EventTriggerCatalogEntry entry)
    {
        return Loc[$"TriggerDisplay_{entry.Kind}"].Value;
    }

    private string GetThresholdLabel(EventTriggerCatalogEntry entry)
    {
        return Loc[$"ThresholdLabel_{entry.Kind}"].ResourceNotFound ? Loc["ThresholdLabel_Value"].Value : Loc[$"ThresholdLabel_{entry.Kind}"].Value;
    }

    private string GetThresholdOperatorDisplay(string op)
    {
        return Loc[$"ThresholdOperator_{op}"].Value;
    }

    private string GetFieldChoiceDisplayName(CustomFieldChoice field)
    {
        var fieldType = Loc[$"FieldType_{field.FieldType}"].ResourceNotFound ? field.FieldType : Loc[$"FieldType_{field.FieldType}"].Value;
        return string.IsNullOrWhiteSpace(fieldType) ? field.Title : $"{field.Title} ({fieldType})";
    }

    private sealed record CustomFieldChoice(string Title, string FieldType);
}
