@page "/automations"
@using DiceCombats.Automations
@using DiceCombats.Components.BlazorComponents.Automations
@inject AutomationConfigurationService ConfigService
@inject IDiceEventPublisher EventPublisher
@inject PopupNotificationService PopupNotificationService

<style>
    .settings-group-name {
    border-radius: 60px;
    padding: 0px 20px 0px 0px;
    margin:10px;
    background-color: darkcyan;
    display: flex;
    align-items: center;
    }

    .settings-group {
    margin:10px;
    padding:10px;
    border-radius:10px;
    background-color:#505050;
    box-shadow: 0 2px 10px rgba(255, 255, 255, 0.2);
    }

    .automation-app-item {
        padding-top: 10px;
        padding-right: 10px;
        min-width: 30%;
        max-width: 30%;
    }

    @@media screen and (max-width: 768px) {
        .automation-app-item {
            min-width: 100%; /* Adjust for smaller screens */
            max-width: 100%;
        }
    }

    .automation-item {
        padding-top: 10px;
        padding-right: 10px;
        min-width: 40%;
        max-width: 50%;
    }

    .assist-box {
        background: #3d3d46;
        border: 1px solid #5f5f6d;
        border-radius: 10px;
        padding: 14px;
        margin: 10px 0;
    }

    .assist-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 12px;
    }

    .assist-example {
        background: #2d2d34;
        border-radius: 8px;
        padding: 10px;
        font-family: monospace;
        font-size: 90%;
        white-space: pre-wrap;
    }

    .kbd {
        display: inline-block;
        padding: 2px 6px;
        border-radius: 4px;
        background: #2d2d34;
        border: 1px solid #666;
        font-family: monospace;
        font-size: 90%;
    }

    .placeholder-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 8px;
    }

    .placeholder-table th,
    .placeholder-table td {
        border-top: 1px solid #5f5f6d;
        padding: 7px;
        vertical-align: top;
    }

    .placeholder-table th {
        text-align: left;
    }

    @@media screen and (max-width: 768px) {
        .automation-item {
            min-width: 100%; /* Adjust for smaller screens */
            max-width: 100%;
        }
    }
</style>

<div class="settings-group">
    <div style="display:flex;align-items:center;">
        <div class="settings-group-name">
            <MudIcon Icon="@Icons.Material.Filled.AutoMode" Size="@Size.Large" style="color:white;margin:10px;" />
            <h3>Automations</h3>
        </div>
        <div>
            <MudButton StartIcon="@Icons.Material.Filled.Save" Variant="Variant.Filled" Color="Color.Success" OnClick="Save">Save</MudButton>
        </div>
    </div>


    <MudExpansionPanel Expanded="@_assistanceExpanded" Elevation="1" ExpandedChanged="() => _assistanceExpanded = !_assistanceExpanded">
        <TitleContent>
            <div class="d-flex">
                <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Color="@Color.Primary" class="mr-3"></MudIcon>
                <MudText class="mr-3">Assistance</MudText>
            </div>
        </TitleContent>
        <ChildContent>
            <div class="assist-box">
                <MudText Typo="Typo.h6">What automations do</MudText>
                <p>
                    Automations let DiceCombats react to combat events. An automation watches for one trigger, then runs one or more actions in order.
                    Typical uses are starting or stopping an external timer, notifying another tool, or sending the current creature information to a local companion app.
                </p>
            </div>

            <div class="assist-grid">
                <div class="assist-box">
                    <MudText Typo="Typo.h6">1. External apps</MudText>
                    <p>
                        Add an external app when several HTTP actions target the same server. Set its base URL, for example
                        <span class="kbd">http://localhost:5000</span>. HTTP actions can then use short relative paths such as
                        <span class="kbd">/api/timer/start</span>.
                    </p>
                    <p>
                        You can also skip external apps and enter an absolute URL directly in an HTTP action.
                    </p>
                </div>

                <div class="assist-box">
                    <MudText Typo="Typo.h6">2. Automations</MudText>
                    <p>
                        Add one automation for each independent rule. Give it a clear name, keep it enabled, then choose when it should run.
                        Some triggers can be restricted to specific creatures, custom fields, options, stats, or numeric thresholds. Empty filters mean “any”.
                    </p>
                </div>

                <div class="assist-box">
                    <MudText Typo="Typo.h6">3. Actions</MudText>
                    <p>
                        Actions run from left to right. Use HTTP requests to call another app and delays to pause between requests.
                        If <span class="kbd">Continue on failure</span> is disabled, the remaining actions are skipped after a failed action.
                    </p>
                </div>

                <div class="assist-box">
                    <MudText Typo="Typo.h6">4. Save and check logs</MudText>
                    <p>
                        Press <span class="kbd">Save</span> after editing. Delivery logs at the bottom of this page show which automation ran, whether it succeeded,
                        the HTTP status code, and possible error messages.
                    </p>
                </div>
            </div>

            <MudExpansionPanels MultiExpansion="true" Dense="true" Elevation="0" Class="mt-2">
                <MudExpansionPanel Text="Placeholder catalogue for HTTP templates">
                    <div class="assist-box">
                        <p>
                            In HTTP URL, body, and header values, use <span class="kbd">{{Name}}</span> placeholders to insert event data.
                            Unknown or unavailable placeholders are replaced by an empty value. The available <span class="kbd">Data.*</span> values depend on the selected trigger.
                        </p>

                        <MudText Typo="Typo.subtitle2">Event metadata, available for every trigger</MudText>
                        <table class="placeholder-table">
                            <tr>
                                <th>Placeholder</th>
                                <th>Meaning</th>
                            </tr>
                            <tr><td><span class="kbd">{{Id}}</span></td><td>Unique event id.</td></tr>
                            <tr><td><span class="kbd">{{Type}}</span></td><td>Technical event type, for example <span class="kbd">combat.initiative.next</span>.</td></tr>
                            <tr><td><span class="kbd">{{Category}}</span></td><td>Event family, for example <span class="kbd">Initiative</span>, <span class="kbd">Creatures</span>, <span class="kbd">Timer</span>, or <span class="kbd">Custom fields</span>.</td></tr>
                            <tr><td><span class="kbd">{{DisplayName}}</span></td><td>Readable event name shown by DiceCombats.</td></tr>
                            <tr><td><span class="kbd">{{OccurredAt}}</span></td><td>UTC timestamp in ISO-8601 format.</td></tr>
                        </table>
                    </div>

                    <div class="assist-box">
                        <MudText Typo="Typo.subtitle2">Event data placeholders</MudText>
                        <table class="placeholder-table">
                            <tr>
                                <th>When available</th>
                                <th>Placeholders</th>
                            </tr>
                            <tr>
                                <td>Most combat events</td>
                                <td><span class="kbd">{{Data.combatId}}</span>, <span class="kbd">{{Data.combatName}}</span></td>
                            </tr>
                            <tr>
                                <td>Next creature in initiative</td>
                                <td><span class="kbd">{{Data.previousCreatureId}}</span>, <span class="kbd">{{Data.previousCreatureName}}</span>, <span class="kbd">{{Data.previousInitiativeIndex}}</span>, <span class="kbd">{{Data.currentCreatureId}}</span>, <span class="kbd">{{Data.currentCreatureName}}</span>, <span class="kbd">{{Data.initiativeIndex}}</span></td>
                            </tr>
                            <tr>
                                <td>Creature got/lost initiative</td>
                                <td><span class="kbd">{{Data.creatureId}}</span>, <span class="kbd">{{Data.creatureName}}</span>, <span class="kbd">{{Data.initiativeIndex}}</span></td>
                            </tr>
                            <tr>
                                <td>Combat timer started/paused/stopped</td>
                                <td><span class="kbd">{{Data.durationSeconds}}</span></td>
                            </tr>
                            <tr>
                                <td>All creature custom-field events</td>
                                <td><span class="kbd">{{Data.creatureId}}</span>, <span class="kbd">{{Data.creatureName}}</span>, <span class="kbd">{{Data.instanceIndex}}</span>, <span class="kbd">{{Data.fieldTitle}}</span>, <span class="kbd">{{Data.fieldType}}</span>, <span class="kbd">{{Data.eventAction}}</span>, <span class="kbd">{{Data.oldValue}}</span>, <span class="kbd">{{Data.newValue}}</span></td>
                            </tr>
                            <tr>
                                <td>Numeric, hit-points, and stats value changes</td>
                                <td><span class="kbd">{{Data.oldNumericValue}}</span>, <span class="kbd">{{Data.numericValue}}</span>, <span class="kbd">{{Data.delta}}</span>, <span class="kbd">{{Data.changeDirection}}</span></td>
                            </tr>
                            <tr>
                                <td>Numeric field with maximum/unit enabled</td>
                                <td><span class="kbd">{{Data.showMaxValue}}</span>, <span class="kbd">{{Data.maximumValue}}</span>, <span class="kbd">{{Data.showUnit}}</span>, <span class="kbd">{{Data.unit}}</span></td>
                            </tr>
                            <tr>
                                <td>Hit-points field</td>
                                <td><span class="kbd">{{Data.maximumValue}}</span>, <span class="kbd">{{Data.oldPercentage}}</span>, <span class="kbd">{{Data.percentage}}</span></td>
                            </tr>
                            <tr>
                                <td>Checkbox and condition options</td>
                                <td><span class="kbd">{{Data.optionIndex}}</span>, <span class="kbd">{{Data.optionName}}</span>, <span class="kbd">{{Data.textLabel}}</span></td>
                            </tr>
                            <tr>
                                <td>Checkbox-grid and text-grid cells</td>
                                <td><span class="kbd">{{Data.rowIndex}}</span>, <span class="kbd">{{Data.rowName}}</span>, <span class="kbd">{{Data.columnIndex}}</span>, <span class="kbd">{{Data.columnName}}</span>, <span class="kbd">{{Data.textLabel}}</span></td>
                            </tr>
                            <tr>
                                <td>Stats field</td>
                                <td><span class="kbd">{{Data.statIndex}}</span>, <span class="kbd">{{Data.statName}}</span></td>
                            </tr>
                            <tr>
                                <td>User custom field saved/removed</td>
                                <td><span class="kbd">{{Data.fieldTitle}}</span>, <span class="kbd">{{Data.fieldType}}</span>, <span class="kbd">{{Data.isUserCustomField}}</span></td>
                            </tr>
                        </table>
                    </div>
                </MudExpansionPanel>

                <MudExpansionPanel Text="Example: send the active creature to an external timer">
                    <div class="assist-box">
                        <p>
                            Create an external app named <span class="kbd">DiceTimer</span> with base URL
                            <span class="kbd">http://localhost:5000</span>. Then create an automation with trigger
                            <span class="kbd">Initiative - Next creature</span> and add an HTTP POST action to
                            <span class="kbd">/api/timer/start</span>.
                        </p>
                        <div class="assist-example">{
  "creature": "{{Data.currentCreatureName}}",
  "combat": "{{Data.combatName}}"
}</div>
                    </div>
                </MudExpansionPanel>

                <MudExpansionPanel Text="Example: react when a numeric field reaches its maximum">
                    <div class="assist-box">
                        <p>
                            On the creature custom field, enable the numeric maximum value display first. Then create an automation with trigger
                            <span class="kbd">Custom fields - Numeric field reached max value</span>. Select the relevant creature and field, or leave them empty to react to any matching field.
                        </p>
                    </div>
                </MudExpansionPanel>

                <MudExpansionPanel Text="Troubleshooting">
                    <div class="assist-box">
                        <p>
                            If nothing happens, check that the automation and the external app are enabled, press Save, then perform the action in Combat Manager again.
                            If a log entry appears with a failure, verify the URL, HTTP method, timeout, and that the external application is running and reachable.
                        </p>
                    </div>
                </MudExpansionPanel>
            </MudExpansionPanels>
        </ChildContent>
    </MudExpansionPanel>


    <ExternalAppsEditor ExternalApps="_config.ExternalApps" OnAdd="AddExternalApp" OnRemove="RemoveExternalApp" />

    <div style="display:flex;align-items:center;">
        <div style="margin:15px;">
            <h4>Automations</h4>
        </div>
        <div>
            <MudButton Style="padding-top:10px;" StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Secondary" OnClick="AddBinding">Add automation</MudButton>
        </div>
    </div>

    <div style="display:flex; flex-wrap:wrap">
        @foreach (var binding in _config.Bindings.ToList())
        {
            <AutomationBindingEditor Binding="binding" ExternalApps="_config.ExternalApps" OnRemove="RemoveBinding" />
        }
    </div>
</div>

<DeliveryLogViewer EventPublisher="EventPublisher" />

@code {
    private AutomationConfiguration _config = new();

    private bool _assistanceExpanded
    {
        get => Preferences.Get("AssistanceAutomations", false);
        set => Preferences.Set("AssistanceAutomations", value);
    }

    protected override async Task OnInitializedAsync()
    {
        _config = await ConfigService.GetConfigurationAsync();
    }

    private void AddExternalApp()
    {
        _config.ExternalApps.Add(new ExternalAppDefinition { Name = "New app" });
    }

    private void RemoveExternalApp(ExternalAppDefinition app)
    {
        _config.ExternalApps.Remove(app);

        foreach (var binding in _config.Bindings)
        {
            foreach (var action in binding.Actions.OfType<HttpRequestActionDefinition>())
            {
                if (action.ExternalAppId == app.Id)
                {
                    action.ExternalAppId = null;
                }
            }
        }
    }

    private void AddBinding()
    {
        _config.Bindings.Add(new EventActionBinding
        {
            Name = "New automation",
            Trigger = new EventTriggerDefinition { Kind = EventTriggerKinds.InitiativeNext }
        });
    }

    private void RemoveBinding(EventActionBinding binding)
    {
        _config.Bindings.Remove(binding);
    }

    private async Task Save()
    {
        await ConfigService.SaveAsync();
        PopupNotificationService.Show("Automations saved", "Successfully saved automations, triggers and external apps", PopupNotificationService.Type.SUCCESS, 2000);
    }
}
