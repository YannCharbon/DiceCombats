@using DiceCombats.Automations
@inject IStringLocalizer<Resources.Localization.Automations> Loc

@{
    var trigger = EnsureTrigger();
}

<MudExpansionPanels Class="automation-item">
    <MudExpansionPanel>
        <TitleContent>
            <div style="display:flex;">
                <MudIcon Icon="@Icons.Material.Filled.ElectricBolt" class="mr-3"
                         Color="@(Binding.IsEnabled == true ? Color.Primary : Color.Dark)"></MudIcon>
                <MudText Style="font-size: 20px; font-weight:700;">@(string.IsNullOrWhiteSpace(Binding.Name) ? Loc["AutomationFallback"].Value : Binding.Name)</MudText>
            </div>
        </TitleContent>
        <ChildContent>
            <MudButton StartIcon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => OnRemove.InvokeAsync(Binding))">@Loc["DeleteAutomation"]</MudButton>

            <MudTextField @bind-Value="Binding.Name" Label="@Loc["AutomationName"]" />
            <MudSwitch @bind-Value="Binding.IsEnabled" Color="Color.Primary" Label="@(Binding.IsEnabled == true ? Loc["Enabled"].Value : Loc["Disabled"].Value)" />

            <TriggerEditor Trigger="trigger" />
            <ActionSequenceEditor Binding="Binding" ExternalApps="ExternalApps" />
        </ChildContent>
    </MudExpansionPanel>
</MudExpansionPanels>

@code {
    [Parameter] public EventActionBinding Binding { get; set; } = new();
    [Parameter] public List<ExternalAppDefinition> ExternalApps { get; set; } = new();
    [Parameter] public EventCallback<EventActionBinding> OnRemove { get; set; }

    private EventTriggerDefinition EnsureTrigger()
    {
        Binding.Trigger ??= new EventTriggerDefinition { Kind = EventTriggerKinds.InitiativeNext };
        return Binding.Trigger;
    }
}
